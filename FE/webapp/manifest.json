{
  "_version": "1.83.1",
  "sap.app": {
    "id": "fasttrackbooking",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.27.0",
      "toolsId": "6c1b8d43-0f94-4026-a1a2-d3c3d231e1aa"
    },
    "dataSources": {
      "annotation": {
        "type": "ODataAnnotation",
        "uri": "annotations/annotation.xml",
        "settings": {
          "localUri": "annotations/annotation.xml"
        }
      },
      "mainService": {
        "uri": "/sap/opu/odata4/sap/zui_booking_v4/srvd/sap/zsv_booking/0001/",
        "type": "OData",
        "settings": {
          "annotations": [
            "annotation"
          ],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.145.3",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {},
        "sap.f": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "fasttrackbooking.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {
        "flexibleColumnLayout": {
          "defaultTwoColumnLayoutType": "TwoColumnsMidExpanded",
          "defaultThreeColumnLayoutType": "ThreeColumnsEndExpanded"
        },
        "routerClass": "sap.f.routing.Router"
      },
      "routes": [
        {
          "pattern": ":?query:",
          "name": "BookingSrvList",
          "target": [
            "BookingSrvList"
          ]
        },
        {
          "pattern": "BookingSrv({key}):?query:",
          "name": "BookingSrvObjectPage",
          "target": [
            "BookingSrvList",
            "BookingSrvObjectPage"
          ]
        },
        {
          "pattern": "BookingSrv({key})/_bookingItem({key2}):?query:",
          "name": "BookingItemSrvObjectPage",
          "target": [
            "BookingSrvList",
            "BookingSrvObjectPage",
            "BookingItemSrvObjectPage"
          ]
        },
        {
          "pattern": "ZZBookingTreeTF({key}):?query:",
          "name": "TreeTFObjectPage",
          "target": [
            "BookingSrvList",
            "TreeTFObjectPage"
          ]
        }
      ],
      "targets": {
        "BookingSrvList": {
          "type": "Component",
          "id": "BookingSrvList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/BookingSrv",
              "variantManagement": "Page",
              "navigation": {
                "BookingSrv": {
                  "detail": {
                    "route": "BookingSrvObjectPage"
                  }
                },
                "ZZBookingTreeTF": {
                  "detail": {
                    "route": "TreeTFObjectPage"
                  }
                }
              },
              "views": {
                "paths": [
                  {
                    "key": "listTab",
                    "annotationPath": "com.sap.vocabularies.UI.v1.SelectionVariant#ViewList"
                  },
                  {
                    "key": "treeTab",
                    "entitySet": "ZZBookingTree",
                    "annotationPath": "com.sap.vocabularies.UI.v1.SelectionVariant#ViewTree"
                  },
                  {
                    "key": "tfTreeTab",
                    "entitySet": "ZZBookingTreeTF",
                    "annotationPath": "com.sap.vocabularies.UI.v1.SelectionVariant#TFViewTree"
                  }
                ]
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "GridTable"
                  }
                },
                "/ZZBookingTree/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "TreeTable",
                    "hierarchyQualifier": "ZH_BOOKINGNODE_FS01"
                  }
                },
                "/ZZBookingTreeTF/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "TreeTable",
                    "hierarchyQualifier": "ZH_BOOKNODETF_FS01"
                  }
                }
              }
            }
          },
          "controlAggregation": "beginColumnPages",
          "contextPattern": ""
        },
        "BookingSrvObjectPage": {
          "type": "Component",
          "id": "BookingSrvObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/BookingSrv",
              "navigation": {
                "_bookingItem": {
                  "detail": {
                    "route": "BookingItemSrvObjectPage"
                  }
                }
              }
            }
          },
          "controlAggregation": "midColumnPages",
          "contextPattern": "/BookingSrv({key})"
        },
        "BookingItemSrvObjectPage": {
          "type": "Component",
          "id": "BookingItemSrvObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/BookingSrv/_bookingItem"
            }
          },
          "controlAggregation": "endColumnPages",
          "contextPattern": "/BookingSrv({key})/_bookingItem({key2})"
        },
        "TreeTFObjectPage": {
          "type": "Component",
          "id": "TreeTFObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/ZZBookingTreeTF"
            }
          },
          "controlAggregation": "midColumnPages",
          "contextPattern": "/ZZBookingTreeTF({key})"
        }
      }
    },
    "rootView": {
      "viewName": "sap.fe.templates.RootContainer.view.Fcl",
      "type": "XML",
      "async": true,
      "id": "appRootView"
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
