@Metadata.layer: #CORE
annotate entity ZC_BOOKING_FS01 with
{
  // Requires @ObjectModel.text.element: ['CustomerName'] on the projection.
  // #TEXT_LAST  -> 'C001 (Acme Corp)'
  // #TEXT_FIRST -> 'Acme Corp (C001)'
  // #TEXT_ONLY  -> 'Acme Corp'
  @UI.textArrangement: #TEXT_LAST
  CustomerId;

  // Status code is meaningless to users -> show only the text ('New', ...)
  @UI.textArrangement: #TEXT_ONLY
  OverallStatus;
}